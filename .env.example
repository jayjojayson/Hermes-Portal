# Hermes Portal – Beispiel-Environment für docker-compose.
# Kopiere zu .env und passe an.

# Webserver
PORTAL_PORT=8090
TZ=Europe/Berlin

# Identität (oder später in der UI setzen)
HP_AGENT_NAME=Hermes
HP_USER_NAME=Du

# Verbindung zum Hermes-Agent
HP_CONNECTION_MODE=local         # local | ssh
HP_AGENT_HOST=127.0.0.1
HP_EXCHANGE_PATH=/mnt/austausch
HP_HERMES_HOME=/root/.hermes
